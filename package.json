{
  "name": "namdev-chiwada-mern",
  "version": "1.0.0",
  "description": "Full MERN stack app for Namdev Chiwada — Authentic Maharashtrian Snacks",

  "engines": {
    "node": "24.x"
  },

  "scripts": {
    "install:all": "cd server && npm install && cd ../client && npm install",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd client && npm run build",
    "start": "cd server && npm start"
  },

  "devDependencies": {
    "concurrently": "^8.2.2"
  },

  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1"
  }
}